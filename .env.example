# =============================================
# NugAI Environment Variables Configuration
# =============================================
# Copy this file to .env.local and fill in actual values
# DO NOT commit .env.local to version control

# =============================================
# Authentication (NextAuth.js v5)
# =============================================
# Secret key for JWT signing (minimum 32 characters recommended)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-min-32-chars"

# The base URL of your application
# Local development: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# =============================================
# Database (Vercel Postgres)
# =============================================
# PostgreSQL connection string
# Format: postgres://user:password@host:port/database
# Get from Vercel Postgres dashboard
DATABASE_URL="postgres://user:password@host:port/database"

# =============================================
# API Key Encryption
# =============================================
# Encryption key for securing provider API keys in database
# Must be exactly 32 bytes (64 hex characters)
# Generate with: openssl rand -hex 32
# DO NOT change this after providers are configured (will break decryption)
API_KEY_ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# =============================================
# AI & Search APIs (Optional - Configure via Admin Dashboard)
# =============================================
# These can now be configured through the admin dashboard
# Provider AI page (/admin/providers) and Search API page (/admin/search-providers)
# 
# DeepSeek API key for LLM operations
# Get from: https://platform.deepseek.com/api-keys
# DEEPSEEK_API_KEY="sk-your-deepseek-key"

# Tavily API key for general web search
# Get from: https://tavily.com/api
# TAVILY_API_KEY="tvly-your-tavily-key"

# Exa API key for academic journal & book search
# Get from: https://exa.ai/
# EXA_API_KEY="your-exa-key"

# =============================================
# Storage (Vercel Blob)
# =============================================
# Read/write token for Vercel Blob storage
# Used for: university logos, user fonts, temporary OCR images
# Get from: Vercel dashboard > Storage > Blob
VERCEL_BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# =============================================
# Monitoring & Error Tracking
# =============================================
# Sentry DSN for error monitoring and performance tracking
# Get from: https://sentry.io/
SENTRY_DSN="https://your-sentry-dsn"

# =============================================
# Cron Jobs Security
# =============================================
# Secret key for authenticating cron job requests
# Generate with: openssl rand -hex 32
# Set in Vercel dashboard > Settings > Environment Variables
CRON_SECRET="generate-with-openssl-rand-hex-32"

# =============================================
# Admin Credentials (Initial Setup)
# =============================================
# Default admin username for first-time setup
# Change immediately after first login
ADMIN_USERNAME="admin"

# Default admin password for first-time setup
# Change immediately after first login (min 8 chars, includes uppercase, lowercase, number)
ADMIN_PASSWORD="ChangeMe123!"

# =============================================
# Notes
# =============================================
# - Never commit .env.local to version control
# - Use strong, unique secrets for production
# - Rotate API keys regularly for security
# - Vercel automatically loads these variables in production
# - For Vercel deployment: set these in Vercel dashboard > Settings > Environment Variables