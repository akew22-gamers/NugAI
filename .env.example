# =============================================
# NugAI Environment Variables Configuration
# =============================================
# Copy this file to .env.local and fill in actual values
# DO NOT commit .env.local to version control!

# =============================================
# Authentication (NextAuth.js v5)
# =============================================
# Secret key for JWT signing (minimum 32 characters recommended)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# The base URL of your application
# Local development: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# =============================================
# Database (Vercel Postgres or Neon)
# =============================================
# PostgreSQL connection string
# Format: postgres://user:password@host:port/database
# Get from Vercel Postgres dashboard or Neon
DATABASE_URL=""

# =============================================
# API Key Encryption
# =============================================
# Encryption key for securing provider API keys in database
# Must be exactly 32 bytes (64 hex characters)
# Generate with: openssl rand -hex 32
# IMPORTANT: DO NOT change this after providers are configured!
API_KEY_ENCRYPTION_KEY=""

# =============================================
# AI & Search APIs (Optional)
# =============================================
# These can be configured through the admin dashboard:
# - Provider AI: /admin/providers
# - Search API: /admin/search-providers
#
# DeepSeek API key for LLM operations
# Get from: https://platform.deepseek.com/api-keys
# DEEPSEEK_API_KEY="sk-your-deepseek-key"

# Tavily API key for general web search
# Get from: https://tavily.com/api
# TAVILY_API_KEY="tvly-your-tavily-key"

# Exa API key for academic journal & book search
# Get from: https://exa.ai/
# EXA_API_KEY="your-exa-key"

# =============================================
# Storage (Vercel Blob)
# =============================================
# Read/write token for Vercel Blob storage
# Used for: university logos, user fonts, temporary OCR images
# Get from: Vercel dashboard > Storage > Blob
VERCEL_BLOB_READ_WRITE_TOKEN=""

# =============================================
# Monitoring & Error Tracking (Optional)
# =============================================
# Sentry DSN for error monitoring and performance tracking
# Get from: https://sentry.io/
# SENTRY_DSN="https://your-sentry-dsn"

# =============================================
# Cron Jobs Security
# =============================================
# Secret key for authenticating cron job requests
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# =============================================
# Admin Credentials (Required for Seed)
# =============================================
# Used when running: npm run db:seed
# Creates admin user with these credentials
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="ChangeMe123!"

# =============================================
# Instructions
# =============================================
# 1. Copy this file to .env.local:
#    cp .env.example .env.local
# 
# 2. Generate secure secrets:
#    NEXTAUTH_SECRET: openssl rand -base64 32
#    API_KEY_ENCRYPTION_KEY: openssl rand -hex 32
#    CRON_SECRET: openssl rand -hex 32
#
# 3. Set your database connection string
#
# 4. Run database setup:
#    npx prisma generate
#    npx prisma migrate deploy
#    npm run db:seed  # Creates admin user
#
# 5. NEVER commit .env.local to version control!
#    (already in .gitignore)
#
# =============================================
# Notes for Deployment
# =============================================
# - Use strong, unique secrets for production
# - Rotate API keys regularly for security
# - Vercel automatically loads these variables in production
# - Set environment variables in Vercel dashboard:
#   Settings > Environment Variables
# - Use the same variable names (case-sensitive)
# - Remove quotes when setting in Vercel dashboard
